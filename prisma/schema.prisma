// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================== ENUMS ==================

enum UserRole {
  CLIENT
  MODEL
  ADMIN
}

enum ModelType {
  ACOMPANANTE
  TRAVESTI
  MASAJISTA
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum KycStatus {
  NOT_SUBMITTED
  SUBMITTED
  APPROVED
  REJECTED
}

// ================== MODELS ==================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  name          String?
  phone         String?
  role          UserRole  @default(CLIENT)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts        Account[]
  sessions        Session[]
  reservations    Reservation[]    @relation("ClientReservations")
  modelProfile    Model?
  reviews        Review[]
  favorites       Favorite[]
  sessionsAdmin   ModelSession[] @relation("SessionsAdmin")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model City {
  id        String   @id @default(cuid())
  name      String   @unique
  state     String
  zones     Zone[]
  models    Model[]
  createdAt DateTime @default(now())
}

model Zone {
  id        String   @id @default(cuid())
  name      String
  cityId    String
  city      City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  models    Model[]
  createdAt DateTime @default(now())

  @@unique([name, cityId])
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  duration    Int      // in minutes
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  modelServices ModelService[]
}

model Model {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cityId      String
  city        City      @relation(fields: [cityId], references: [id])
  zoneId      String?
  zone        Zone?     @relation(fields: [zoneId], references: [id])
  
  // Profile
  name        String
  tagline     String?
  bio         String?   @db.Text
  age         Int
  type        ModelType @default(ACOMPANANTE)
  ethnicity   String?
  height      Int?      // in cm
  weight      Int?      // in kg
  languages   String[]  @default(["Español"])
  
  // Media
  mainPhoto   String
  gallery     String[]  // JSON array of photo URLs
  
  // Stats
  rating      Decimal   @default(0) @db.Decimal(3, 2)
  reviewCount Int       @default(0)
  viewCount   Int       @default(0)
  bookingCount Int      @default(0)
  
  // Verification
  verified    Boolean   @default(false)
  verifiedAt  DateTime?
  
  // KYC - INE verification (legally required in Mexico)
  kycStatus        KycStatus  @default(NOT_SUBMITTED)
  kycSubmittedAt   DateTime?
  kycVerifiedAt    DateTime?
  kycRejectedReason String?
  ineFrontUrl     String?    // INE front photo URL
  ineBackUrl      String?    // INE back photo URL
  selfieUrl       String?    // Selfie holding INE
  
  // Availability
  availableHours String? // JSON: {"monday": {"start": "09:00", "end": "21:00"}, ...}
  
  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  services    ModelService[]
  reservations Reservation[]
  reviews     Review[]
  favorites   Favorite[]
  sessions    ModelSession[]
  calendar    CalendarEvent[]

  @@index([cityId])
  @@index([type])
  @@index([rating])
}

model ModelService {
  id        String   @id @default(cuid())
  modelId   String
  serviceId String
  price     Decimal  @db.Decimal(10, 2)
  active    Boolean  @default(true)
  
  model   Model   @relation(fields: [modelId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])
  
  @@unique([modelId, serviceId])
}

model CalendarEvent {
  id        String   @id @default(cuid())
  modelId   String
  model     Model    @relation(fields: [modelId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  startTime String   // "HH:MM"
  endTime   String   // "HH:MM"
  blocked   Boolean  @default(false)
  note      String?
  
  createdAt DateTime @default(now())
  
  @@unique([modelId, date])
  @@index([modelId])
}

model Reservation {
  id          String            @id @default(cuid())
  userId      String
  modelId     String
  user        User              @relation("ClientReservations", fields: [userId], references: [id])
  model       Model             @relation(fields: [modelId], references: [id])
  
  // Booking details
  date        DateTime          @db.Date
  startTime   String            // "HH:MM"
  endTime     String            // "HH:MM"
  address     String?           @db.Text
  notes       String?           @db.Text
  
  // Status
  status      ReservationStatus @default(PENDING)
  
  // Payment
  totalAmount Decimal           @db.Decimal(10, 2)
  paymentStatus PaymentStatus  @default(PENDING)
  stripePaymentId String?
  
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  
  @@index([userId])
  @@index([modelId])
  @@index([date])
  @@index([status])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  modelId   String
  user      User     @relation(fields: [userId], references: [id])
  model     Model    @relation(fields: [modelId], references: [id], onDelete: Cascade)
  
  rating    Int      // 1-5
  title     String?
  content   String?  @db.Text
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([userId, modelId])
  @@index([modelId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  modelId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  model     Model    @relation(fields: [modelId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@unique([userId, modelId])
}

model ModelSession {
  id        String   @id @default(cuid())
  modelId   String
  adminId   String
  model     Model    @relation(fields: [modelId], references: [id], onDelete: Cascade)
  admin     User     @relation("SessionsAdmin", fields: [adminId], references: [id])
  
  date      DateTime @db.Date
  notes     String?  @db.Text
  outcome   String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([modelId])
}

model GiftCard {
  id        String   @id @default(cuid())
  code      String   @unique
  amount    Decimal  @db.Decimal(10, 2)
  balance   Decimal  @db.Decimal(10, 2)
  clientId  String?
  expiresAt DateTime
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}
